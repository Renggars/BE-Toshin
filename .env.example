# ============================================================
# TOSHIN BACKEND - Environment Variables Template
# Salin file ini menjadi .env dan sesuaikan nilainya.
# ============================================================

# App Environment
NODE_ENV=development
PORT=4001
TCP_PORT=4210

# ============================================================
# Database Configuration
# ============================================================
DB_ROOT_PASSWORD=rootpassword123
DB_NAME=toshin
DB_PORT_EXTERNAL=3307

# Prisma Connection URL
# Jika jalan lewat Docker  : mysql://root:rootpassword123@mysql:3306/toshin
# Jika jalan lokal (direct): mysql://root:rootpassword123@localhost:3307/toshin
DATABASE_URL=mysql://root:rootpassword123@mysql:3306/toshin

# ============================================================
# Redis Configuration
# ============================================================
REDIS_PASSWORD=yourpassword123
REDIS_PORT_EXTERNAL=6379
REDIS_ENABLED=true

# Redis URL
# Jika jalan lewat Docker  : redis://:yourpassword123@redis:6379
# Jika jalan lokal (direct): redis://:yourpassword123@localhost:6379
REDIS_URL=redis://:yourpassword123@redis:6379

# ============================================================
# JWT Configuration
# ============================================================
JWT_SECRET=yourJwtSecret_gantiDenganStringAcakPanjang
JWT_ACCESS_EXPIRATION_MINUTES=1440
JWT_REFRESH_EXPIRATION_DAYS=7

# ============================================================
# Email Configuration (Nodemailer)
# ============================================================
EMAIL_USER=yourEmail@gmail.com
EMAIL_PASS=yourEmailAppPassword

# ============================================================
# Monitoring (Optional - isi jika pakai Grafana)
# ============================================================
GRAFANA_PASSWORD=admin

# ============================================================
# phpMyAdmin External Port (Optional)
# ============================================================
PMA_PORT_EXTERNAL=8081
REDIS_INSIGHT_PORT=8001
